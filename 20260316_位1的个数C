//======================
//思路：利用十进制转二进制的辗转相除法
//时间复杂度：O(log n)
//空间复杂度：O(1)
//======================
int hammingWeight(int n) {
    int count = 0;
    while (n != 1) {
        if (n % 2 != 0)
            count++;
        n /= 2;
    }
    return count + 1;
}
